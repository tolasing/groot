{
    "name": "IsaacLab XR",
    "build": {
        "dockerfile": "../docker/Dockerfile.base",
        "context": "..",
        "args": {
            "ISAACSIM_BASE_IMAGE_ARG": "nvcr.io/nvidia/isaac-sim",
            "ISAACSIM_VERSION_ARG": "6.0.0-dev2",
            "ISAACSIM_ROOT_PATH_ARG": "/isaac-sim",
            "ISAACLAB_PATH_ARG": "/workspace/isaaclab",
            "DOCKER_USER_HOME_ARG": "/root"
        }
    },
    "workspaceFolder": "/workspace/isaaclab",

    // Environment variables set inside the container
    "remoteEnv": {
        "NV_CXR_ENABLE_PUSH_DEVICES": "0",
        "OMNI_KIT_ALLOW_ROOT": "1",
        "ISAACSIM_PATH": "/workspace/isaaclab/_isaac_sim"
    },

    // NVIDIA GPU access
    "runArgs": [
        "--gpus", "all",
        "--network", "host",
        "--privileged"
    ],

    // VS Code extensions to install inside the container
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.pylance",
                "ms-python.black-formatter",
                "charliermarsh.ruff",
                "ms-vscode.cpptools",
                "twxs.cmake",
                "eamodio.gitlens",
                "mhutchie.git-graph",
                "ms-azuretools.vscode-docker",
                "njpwerner.autodocstring"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/workspace/isaaclab/_isaac_sim/python.sh",
                "editor.formatOnSave": true,
                "editor.rulers": [120],
                "files.trimTrailingWhitespace": true
            }
        }
    },

    // Forward ports used by Isaac Sim and CloudXR
    "forwardPorts": [
        8211,   // Isaac Sim streaming
        49100,  // CloudXR signaling
        48322   // CloudXR WSS proxy
    ],

    "postCreateCommand": "echo 'IsaacLab XR devcontainer ready'",

    "remoteUser": "root"
}
