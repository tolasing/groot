{
  "name": "Isaac Lab — ROS2",
  "dockerComposeFile": [
    "../../docker/docker-compose.yaml",
    "docker-compose.devcontainer.yaml"
  ],
  "service": "isaac-lab-ros2",
  "workspaceFolder": "/groot_ws",
  "workspaceMount": "source=${localWorkspaceFolder},target=/groot_ws,type=bind,consistency=cached",
  "postCreateCommand": "mkdir -p /groot_ws/src && ln -sfn /workspace/isaaclab /groot_ws/src/isaaclab",
  "overrideCommand": false,
  "shutdownAction": "stopCompose",
  "remoteEnv": {
    "ISAACSIM_PATH": "/workspace/isaaclab/_isaac_sim",
    "OMNI_KIT_ALLOW_ROOT": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-iot.vscode-ros",
        "anthropic.claude-code"
      ]
    }
  }
}
